# MCP Proxy config
PORT=9000
DATA_DIR=./data
EXTERNAL_URL=http://localhost:9000

# JSON array of upstream MCP servers
# Each entry needs: name, url, headers (array of {name,value}), and optional auth
# For OAuth upstreams, set auth.type to "oauth" (optionally with client_id, client_secret, scopes)
UPSTREAMS_JSON=[{"name":"example","url":"https://mcp.example.com/mcp","headers":[],"auth":{"type":"oauth"}}]
